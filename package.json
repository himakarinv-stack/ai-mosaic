    "ai-mosaic"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/himakarinv-stack/ai-mosaic.git"
  },
  "bugs": {
    "url": "https://github.com/himakarinv-stack/ai-mosaic/issues"
