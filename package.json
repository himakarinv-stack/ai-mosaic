{
  "name": "ai-mosaic",
  "version": "0.1.0",
  "description": "MCP server for Angular architecture, code quality, and version-aware review — reviewer, coder, and architect for Angular 19+.",
  "type": "module",
  "license": "MIT",
  "author": "Himakar Reddy <himakarinv@gmail.com>",
  "bin": {
    "ai-mosaic": "bin/ai-mosaic.js",
    "ai-mosaic-setup": "bin/ai-mosaic-setup.js"
  },
  "files": [
    "bin",
    "dist",
    "standards",
    "templates",
    "scripts/setup.mjs",
    "scripts/copy-standards.mjs",
    "ai-mosaic.config.example.json",
