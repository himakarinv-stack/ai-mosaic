{
  "$schema": "https://raw.githubusercontent.com/himakarinv-stack/ai-mosaic/main/ai-mosaic.schema.json",
  "severity": "balanced",
  "ignore": ["**/legacy/**", "**/dist/**", "**/node_modules/**"],
  "strictRules": ["onpush", "signals-for-state"],
  "storybook": {
    "storiesGlob": "**/*.stories.@(ts|tsx)",
    "requireAutodocs": true
  },
  "cliBridge": {
    "enabled": true,
    "defaultProject": null
  }
}
